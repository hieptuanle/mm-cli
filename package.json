{
    "name": "mm-cli",
    "version": "0.1.0",
    "description": "Mattermost CLI for humans and agents (TypeScript port of mattermost-cli)",
    "type": "module",
    "bin": {
        "mm": "./dist/index.js"
    },
    "files": [
        "dist",
        "skills",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "type-check": "tsc --noEmit",
        "start": "node dist/index.js",
        "prepublishOnly": "pnpm build"
    },
    "keywords": [
        "mattermost",
        "cli",
        "chat",
        "agent",
        "llm",
        "messaging"
    ],
    "author": "hieptuanle",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hieptuanle/mm-cli.git"
    },
    "bugs": {
        "url": "https://github.com/hieptuanle/mm-cli/issues"
    },
    "homepage": "https://github.com/hieptuanle/mm-cli#readme",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=20.18.1"
    },
    "dependencies": {
        "chalk": "5.6.2",
        "commander": "14.0.2",
        "prompts": "2.4.2",
        "undici": "7.22.0"
    },
    "devDependencies": {
        "@types/node": "25.0.10",
        "@types/prompts": "2.4.9",
        "typescript": "5.9.3"
    },
    "packageManager": "pnpm@10.0.0"
}
