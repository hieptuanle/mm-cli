{
    "name": "mm-cli",
    "version": "0.1.0",
    "description": "Mattermost CLI for humans and agents",
    "type": "module",
    "bin": {
        "mm": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "type-check": "tsc --noEmit",
        "start": "node dist/index.js",
        "prepublishOnly": "pnpm build"
    },
    "engines": {
        "node": ">=20.18.1"
    },
    "dependencies": {
        "chalk": "5.6.2",
        "commander": "14.0.2",
        "prompts": "2.4.2",
        "undici": "7.22.0"
    },
    "devDependencies": {
        "@types/node": "25.0.10",
        "@types/prompts": "2.4.9",
        "typescript": "5.9.3"
    },
    "packageManager": "pnpm@10.0.0"
}
